# Backend Environment Variables Example

# ==========================================
# REQUIRED CONFIGURATION
# ==========================================

# PostgreSQL Connection URL
# Format: postgresql://username:password@host:port/database_name
# Local Development: postgresql://imsuser:password123@localhost:5432/imsdb
# Docker Compose: postgresql://imsuser:password123@db:5432/imsdb
# Render: postgresql://imsuser:password123@your-db.render.com:5432/imsdb
DATABASE_URL=postgresql://imsuser:changeme_strong_password@localhost:5432/imsdb

# CORS Origins (comma-separated list of allowed frontend URLs)
# Development: http://localhost:3000,http://localhost:5173,http://localhost:8080
# Production: https://your-domain.com,https://app.your-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ==========================================
# APPLICATION SETTINGS (Optional)
# ==========================================

# Application environment
ENV=development

# API Server Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# Logging Level: debug, info, warning, error
LOG_LEVEL=info

# ==========================================
# DEPLOYMENT NOTES
# ==========================================
# 
# RENDER DEPLOYMENT:
# 1. Create PostgreSQL database and copy internal URL to DATABASE_URL
# 2. Set CORS_ORIGINS to include your frontend domain
#    Example: https://your-app.onrender.com,https://app.onrender.com
# 3. Use https:// for production domains (never http)
# 
# LOCAL DOCKER:
# docker-compose will automatically set these values from .env file
# 
# ENVIRONMENT VERIFICATION:
# - GET /health endpoint will return {"status": "ok", "version": "1.0.0"}
# - Check logs for any connection errors
# - Verify CORS headers in response: Access-Control-Allow-Origin
#
# ==========================================
